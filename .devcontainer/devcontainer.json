{
    "image": "mcr.microsoft.com/devcontainers/python:3.14-trixie",
    "postCreateCommand": "python3 -m pip install --user basedpyright mypy",
    "customizations": {
        "vscode": {
            "extensions": [
                "aaron-bond.better-comments",
                "christian-kohler.path-intellisense",
                "detachhead.basedpyright",
                "eamodio.gitlens",
                "fosshaas.fontsize-shortcuts",
                "GitHub.vscode-pull-request-github",
                "IgorSbitnev.error-gutters",
                "mateocerquetella.xcode-12-theme",
                "matangover.mypy",
                "oderwat.indent-rainbow",
                "seunlanlege.action-buttons",
                "SirTori.indenticator",
                "usernamehw.errorlens",
                "vsls-contrib.gitdoc",
                "yzhang.markdown-all-in-one"
            ],
            "settings": {
                "gitlens.showWhatsNewAfterUpgrades": false,
                "gitlens.showWelcomeOnInstall": false,
                "editor.wordWrap": "on",
                "editor.inlayHints.enabled": "off",
                "editor.fontSize": 18,
                "editor.rulers": [
                    80
                ],
                "editor.tokenColorCustomizations": {
                    "textMateRules": [
                        {
                            "scope": "comment",
                            "settings": {
                                "fontStyle": "italic"
                            }
                        }
                    ]
                },
                "python.analysis.typeCheckingMode": "off",
                "basedpyright.analysis.typeCheckingMode": "all",
                "basedpyright.analysis.configFilePath": "${workspaceFolder}/pyrightconfig.json",
                "basedpyright.analysis.diagnosticMode": "workspace",
                "gitdoc.commitValidationLevel": "none",
                "gitdoc.enabled": true,
                "chat.disableAIFeatures": true,
                "workbench.colorTheme": "Xcode Classic (Light)",
                "actionButtons": {
                    "commands": [
                        {
                            "cwd": "{workspaceFolder}",
                            "name": "$(pencil) Format file",
                            "useVsCodeApi": true,
                            "command": "editor.action.formatDocument"
                        },
                        {
                            "cwd": "${workspaceFolder}",
                            "name": "$(terminal-view-icon) New Terminal",
                            "useVsCodeApi": true,
                            "command": "workbench.action.terminal.newInActiveWorkspace"
                        },
                        {
                            "name": "$(terminal-kill) Kill all Terminals",
                            "useVsCodeApi": true,
                            "command": "workbench.action.terminal.killAll"
                        }
                    ],
                    "defaultColor": "none",
                    "reloadButton": "↻",
                    "loadNpmCommands": false
                }
            }
        }
    }
}
